<!DOCTYPE html> <html lang="en"> <head> <meta charset="UTF-8"> <meta name="viewport" content="width=device-width, initial-scale=1.0"> <style>:root{--accent:#89b4fa;--border:rgba(255,255,255,.08);--glass:rgba(255,255,255,.04);--text:rgba(255,255,255,.92)}*{margin:0;padding:0;box-sizing:border-box;font-family:'Inter',-apple-system,sans-serif;user-select:none}body{background:#000;color:var(--text);overflow:hidden;height:100vh;width:100vw}#app-root{height:100%;width:100%;display:flex;align-items:center;justify-content:center;position:relative}.ambient-bg{position:fixed;inset:-10px;z-index:1;background-size:cover;background-position:center;filter:brightness(.35) blur(10px);transition:opacity .5s ease}.overlay-dim{position:fixed;inset:0;z-index:2;background:rgba(0,0,0,.2)}.core-pane{position:relative;z-index:10;width:95%;max-width:600px;height:85vh;background:var(--glass);backdrop-filter:blur(25px);-webkit-backdrop-filter:blur(25px);border:1px solid var(--border);border-radius:20px;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 20px 40px rgba(0,0,0,.4)}.nav{display:flex;justify-content:space-between;align-items:center;padding:20px 25px;border-bottom:1px solid var(--border)}.nav h2{font-size:11px;font-weight:800;color:var(--accent);letter-spacing:2px}.close-btn{cursor:pointer;font-size:24px;opacity:.5;transition:.2s;color:#fff;line-height:1}.close-btn:hover{opacity:1}.form-container{flex:1;width:100%;background:0 0}iframe{width:100%;height:100%;border:none;filter:invert(90%) hue-rotate(180deg) brightness(1.1)}</style> </head> <body> <div id="app-root"> <div class="ambient-bg" id="bg-layer"></div> <div class="overlay-dim"></div> <div class="core-pane"> <div class="nav"> <h2>Game Request</h2> <div class="close-btn" onclick="window.parent.postMessage('close','*')">×</div> </div> <div class="form-container"> <iframe src="https://docs.google.com/forms/d/e/1FAIpQLScF3UHepiXpzqyNQS79rGAFket02REtldbS4wW8mR8DLTghIw/viewform?embedded=true" frameborder="0" marginheight="0" marginwidth="0">Laden…</iframe> </div> </div> </div> <script>const bgLayer=document.getElementById('bg-layer'),DB_NAME="hrn_db";async function loadBackground(){const e=indexedDB.open(DB_NAME,1);e.onsuccess=e=>{const t=e.target.result;if(!t.objectStoreNames.contains('background'))return void setDefaultBg();const n=t.transaction('background','readonly').objectStore('background').get('current_bg');n.onsuccess=()=>{const e=n.result?.value;e?bgLayer.style.backgroundImage=`url('${e}')`:setDefaultBg()}},e.onerror=()=>setDefaultBg()}function setDefaultBg(){bgLayer.style.backgroundImage="url('https://img.freepik.com/free-vector/black-background-with-wavy-lines_52683-76524.jpg')"}loadBackground();</script> </body> </html>
