<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings</title>
    <style>
        :root {
            --accent: #89b4fa;
            --border: rgba(255, 255, 255, 0.08);
            --glass: rgba(255, 255, 255, 0.04);
            --text: rgba(255, 255, 255, 0.92);
            --subtext: rgba(255, 255, 255, 0.5);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', -apple-system, sans-serif;
            user-select: none;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background: #000;
            color: var(--text);
            overflow: hidden;
            height: 100vh;
            width: 100vw;
        }

        #app-root {
            height: 100%;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .ambient-bg {
            position: fixed;
            inset: -10px;
            z-index: 1;
            background-size: cover;
            background-position: center;
            filter: brightness(0.40) blur(10px);
            transition: opacity 0.5s ease;
        }

        .overlay-dim {
            position: fixed;
            inset: 0;
            z-index: 2;
            background: rgba(0, 0, 0, 0.2);
        }

        .core-pane {
            position: relative;
            z-index: 10;
            width: 92%;
            max-width: 400px;
            max-height: 85vh;
            background: var(--glass);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 25px;
            display: flex;
            flex-direction: column;
            gap: 16px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
            overflow-y: auto;
        }

        .core-pane::-webkit-scrollbar { display: none; }

        .nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 5px;
        }

        .nav h2 {
            font-size: 11px;
            font-weight: 800;
            color: var(--accent);
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .close-btn {
            cursor: pointer;
            font-size: 20px;
            opacity: 0.5;
            transition: 0.2s;
            color: #fff;
            display: flex;
        }

        .close-btn:hover { opacity: 1; }

        .row { width: 100%; }

        label {
            font-size: 10px;
            font-weight: 700;
            color: var(--subtext);
            display: block;
            margin-bottom: 8px;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        input[type="text"] {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            padding: 12px 14px;
            border-radius: 10px;
            color: #fff;
            font-size: 12px;
            outline: none;
            transition: border-color 0.2s;
        }

        input[type="text"]:focus { border-color: var(--accent); }

        input[type="color"] {
            -webkit-appearance: none;
            width: 100%;
            height: 40px;
            background: none;
            border: 1px solid var(--border);
            border-radius: 10px;
            cursor: pointer;
            padding: 4px;
        }
        input[type="color"]::-webkit-color-swatch { border: none; border-radius: 6px; }

        .btn-action {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            padding: 12px;
            border-radius: 10px;
            color: #fff;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }

        .btn-action:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.2);
        }

        .flex-group {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .btn-reset {
            background: rgba(243, 139, 168, 0.08);
            border-color: rgba(243, 139, 168, 0.2);
            color: #f38ba8;
        }
        .btn-reset:hover { background: rgba(243, 139, 168, 0.15); }

        .slider-wrap {
            width: 100%;
            height: 40px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            border-radius: 10px;
            display: flex;
            align-items: center;
            padding: 0 15px;
            position: relative;
            cursor: ew-resize;
        }

        .slider-track {
            width: 100%;
            height: 3px;
            background: rgba(255, 255, 255, 0.1);
            position: relative;
        }

        .slider-fill {
            position: absolute;
            height: 100%;
            background: var(--accent);
            width: 0%;
        }

        .slider-knob {
            position: absolute;
            width: 12px;
            height: 12px;
            background: #fff;
            border-radius: 50%;
            left: 0%;
            top: 50%;
            transform: translate(-50%, -50%);
            box-shadow: 0 0 10px rgba(0,0,0,0.5);
        }

        .toggle-box {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
            border: 1px solid var(--border);
            cursor: pointer;
            transition: 0.2s;
        }

        .toggle-box:hover { background: rgba(255, 255, 255, 0.08); }

        .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: rgba(255,255,255,0.1);
            transition: 0.3s;
        }

        .active .dot {
            background: var(--accent);
            box-shadow: 0 0 15px var(--accent);
        }

        .hidden-file { display: none; }
    </style>
</head>
<body>

<div id="app-root">
    <div class="ambient-bg" id="bg-layer"></div>
    <div class="overlay-dim"></div>
    <div class="core-pane">
        <div class="nav">
            <h2>Settings</h2>
            <div class="close-btn" id="closeBtn">×</div>
        </div>

        <div class="row">
            <div class="toggle-box" id="nav-toggle">
                <label style="margin:0;opacity:1;cursor:pointer;color:#fff">Side Navigation</label>
                <div class="dot"></div>
            </div>
        </div>

        <div class="row flex-group">
            <div>
                <label>Accent Color</label>
                <input type="color" id="clr">
            </div>
            <div>
                <label>Wallpaper</label>
                <button class="btn-action" id="uploadBtn">Upload File</button>
                <input type="file" id="bg-file" class="hidden-file" accept="image/*">
            </div>
        </div>

        <div class="row">
            <label>Remote Wallpaper URL</label>
            <input type="text" id="bg" placeholder="https://...">
        </div>

        <div class="row flex-group">
            <button class="btn-action btn-reset" id="resetBgBtn">Reset Background</button>
            <button class="btn-action btn-reset" id="resetAllBtn">Purge All Data</button>
        </div>

        <div class="row">
            <div class="toggle-box" id="part-toggle">
                <label style="margin:0;opacity:1;cursor:pointer;color:#fff">Background Particles</label>
                <div class="dot"></div>
            </div>
        </div>

        <div class="row flex-group">
            <div>
                <label>Density</label>
                <div class="slider-wrap" id="slider-int" data-min="0.1" data-max="4.0" data-step="0.1">
                    <div class="slider-track">
                        <div class="slider-fill"></div>
                        <div class="slider-knob"></div>
                    </div>
                </div>
            </div>
            <div>
                <label>Opacity</label>
                <div class="slider-wrap" id="slider-op" data-min="0.1" data-max="1" data-step="0.05">
                    <div class="slider-track">
                        <div class="slider-fill"></div>
                        <div class="slider-knob"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row flex-group">
            <div>
                <label>Page Title</label>
                <input type="text" id="title">
            </div>
            <div>
                <label>Favicon URL</label>
                <input type="text" id="fav">
            </div>
        </div>
    </div>
</div>

<script>
(async () => {
    const sync = () => { try { window.parent.postMessage('sync', '*') } catch (e) { console.warn('Sync failed', e) } };
    const defaultBg = "https://img.freepik.com/free-vector/black-background-with-wavy-lines_52683-76524.jpg";
    const defaults = { title: 'HRN | CORE', clr: '#89b4fa', op: 0.8, int: 1.1, fav: '', part: true };
    let db; const DB_NAME = "hrn_db"; const DB_VERSION = 1;

    async function initDB() {
        return new Promise(r => {
            const req = indexedDB.open(DB_NAME, DB_VERSION);
            req.onupgradeneeded = e => {
                db = e.target.result;
                if (!db.objectStoreNames.contains('background')) db.createObjectStore('background', { keyPath: 'id' });
            };
            req.onsuccess = e => { db = e.target.result; r(); };
            req.onerror = () => r();
        });
    }

    async function saveBackground(value) {
        if (!db) await initDB();
        let storeVal = value;
        if (value instanceof Blob) storeVal = await new Promise(res => {
            const fr = new FileReader(); fr.onload = e => res(e.target.result); fr.readAsDataURL(value);
        });
        const tx = db.transaction('background', 'readwrite');
        tx.objectStore('background').put({ id: 'current_bg', value: storeVal, timestamp: Date.now() });
    }

    async function loadBackground() {
        if (!db) await initDB();
        const tx = db.transaction('background', 'readonly');
        const req = tx.objectStore('background').get('current_bg');
        return new Promise(r => {
            req.onsuccess = () => r(req.result ? req.result.value : defaultBg);
            req.onerror = () => r(defaultBg);
        });
    }

    async function updateBg(val) {
        const bgLayer = document.getElementById('bg-layer');
        let displayUrl = defaultBg;
        if (val instanceof Blob) {
            displayUrl = URL.createObjectURL(val);
            await saveBackground(val);
        } else if (typeof val === 'string' && val.length > 0) {
            displayUrl = val;
            await saveBackground(val);
        } else {
            displayUrl = defaultBg;
            await saveBackground(defaultBg);
        }
        bgLayer.style.backgroundImage = `url('${displayUrl}')`;
        sync();
    }

    async function resetBg() {
        document.getElementById('bg').value = "";
        localStorage.removeItem('hrn_bg');
        await updateBg(defaultBg);
    }

    async function resetAll() {
        localStorage.clear();
        if (db) db.transaction('background', 'readwrite').objectStore('background').delete('current_bg');
        document.getElementById('title').value = defaults.title;
        document.getElementById('fav').value = defaults.fav;
        document.getElementById('clr').value = defaults.clr;
        document.getElementById('bg').value = "";
        document.documentElement.style.setProperty('--accent', defaults.clr);
        setSliderUI('slider-int', defaults.int);
        setSliderUI('slider-op', defaults.op);
        navBtn.classList.add('active');
        partBtn.classList.add('active');
        await updateBg(defaultBg);
        sync();
    }

    function setSliderUI(id, val) {
        const wrap = document.getElementById(id);
        const min = parseFloat(wrap.dataset.min), max = parseFloat(wrap.dataset.max);
        const p = ((val - min) / (max - min)) * 100;
        wrap.querySelector('.slider-fill').style.width = p + '%';
        wrap.querySelector('.slider-knob').style.left = p + '%';
    }

    function initSlider(id, key) {
        const wrap = document.getElementById(id);
        const min = parseFloat(wrap.dataset.min), max = parseFloat(wrap.dataset.max), step = parseFloat(wrap.dataset.step);
        let dragging = false;
        const update = e => {
            const rect = wrap.getBoundingClientRect();
            const x = e.touches ? e.touches[0].clientX : e.clientX;
            let pos = Math.max(0, Math.min(1, (x - rect.left) / rect.width));
            let val = min + pos * (max - min);
            val = Math.round(val / step) * step;
            setSliderUI(id, val);
            localStorage.setItem('hrn_' + key, val.toFixed(2));
            sync();
        };
        wrap.addEventListener('mousedown', e => { dragging = true; update(e) });
        window.addEventListener('mousemove', e => { if (dragging) update(e) });
        window.addEventListener('mouseup', () => dragging = false);
        wrap.addEventListener('touchstart', e => { dragging = true; update(e) });
        window.addEventListener('touchmove', e => { if (dragging) update(e) });
        window.addEventListener('touchend', () => dragging = false);
        const saved = parseFloat(localStorage.getItem('hrn_' + key) || defaults[key]);
        setSliderUI(id, saved);
    }

    initSlider('slider-int', 'int');
    initSlider('slider-op', 'op');

    ['title', 'clr', 'fav', 'bg'].forEach(id => {
        const el = document.getElementById(id);
        let savedVal = localStorage.getItem('hrn_' + id);
        
        // Voorkom dat data:urls in het tekstveld getoond worden
        if (id === 'bg' && savedVal && savedVal.startsWith('data:')) {
            el.value = "";
        } else {
            el.value = savedVal || (id === 'bg' ? '' : defaults[id]);
        }

        el.addEventListener('input', () => {
            localStorage.setItem('hrn_' + id, el.value);
            if (id === 'clr') document.documentElement.style.setProperty('--accent', el.value);
            if (id === 'bg') updateBg(el.value);
            sync();
        });
    });

    const navBtn = document.getElementById('nav-toggle');
    let useSideNav = localStorage.getItem('hrn_nav_mode') !== 'bottom';
    if (useSideNav) navBtn.classList.add('active');
    navBtn.addEventListener('click', () => {
        useSideNav = !useSideNav;
        navBtn.classList.toggle('active', useSideNav);
        localStorage.setItem('hrn_nav_mode', useSideNav ? 'side' : 'bottom');
        sync();
    });

    const partBtn = document.getElementById('part-toggle');
    let partActive = localStorage.getItem('hrn_part') !== 'false';
    if (partActive) partBtn.classList.add('active');
    partBtn.addEventListener('click', () => {
        partActive = !partActive;
        partBtn.classList.toggle('active', partActive);
        localStorage.setItem('hrn_part', partActive);
        sync();
    });

    document.getElementById('uploadBtn').addEventListener('click', () => document.getElementById('bg-file').click());
    document.getElementById('bg-file').addEventListener('change', async e => {
        const file = e.target.files[0];
        if (!file) return;
        await updateBg(file);
        // Zet tekstveld op leeg bij upload, zodat data-url niet bewaard wordt in localStorage tekst-key
        document.getElementById('bg').value = "";
        localStorage.setItem('hrn_bg', "");
    });

    document.getElementById('resetBgBtn').addEventListener('click', resetBg);
    document.getElementById('resetAllBtn').addEventListener('click', resetAll);
    document.getElementById('closeBtn').addEventListener('click', () => window.parent.postMessage('close', '*'));

    document.documentElement.style.setProperty('--accent', localStorage.getItem('hrn_clr') || defaults.clr);
    await initDB();
    const bg = await loadBackground();
    await updateBg(bg);
})();
</script>
</body>
</html>
